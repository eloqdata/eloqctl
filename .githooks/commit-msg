#!/usr/bin/env bash
set -euo pipefail

msg_file="$1"
pattern='^(feat|fix|perf|refactor|docs|test|build|ci|chore|revert)(\([^)]+\))?!?: .+'

first_line="$(head -n 1 "$msg_file")"

if [[ ! "$first_line" =~ $pattern ]]; then
  echo "commit message must follow Conventional Commits, e.g. 'fix: correct version output'" >&2
  exit 1
fi
