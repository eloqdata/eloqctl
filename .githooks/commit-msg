#!/usr/bin/env bash
set -euo pipefail

msg_file="$1"
pattern='^(feat|fix|perf|refactor|docs|test|build|ci|chore|revert|style)(\([^)]+\))?!?: .+'

first_line="$(head -n 1 "$msg_file")"

# Allow common Git-generated subjects.
if [[ "$first_line" =~ ^(Merge\ |Revert\ \"|fixup!\ |squash!\ ) ]]; then
  exit 0
fi

if [[ ! "$first_line" =~ $pattern ]]; then
  echo "commit message must follow Conventional Commits, e.g. 'fix: correct version output'" >&2
  exit 1
fi
