FROM python:3.13-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        git \
    && rm -rf /var/lib/apt/lists/*

RUN git clone --depth 1 https://github.com/tair-opensource/resp-compatibility.git /opt/resp-compatibility

WORKDIR /opt/resp-compatibility

RUN pip install --no-cache-dir -r requirements.txt

COPY tests/e2e/resp_compat/resp_compatibility_eloq.py /opt/resp-compatibility/resp_compatibility_eloq.py

CMD ["sleep", "infinity"]
