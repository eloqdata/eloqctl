FROM python:3.13-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        gdb \
        gdbserver \
        iproute2 \
        less \
        lsof \
        procps \
        strace \
    && rm -rf /var/lib/apt/lists/*

COPY tests/e2e/cmd_stress_py/requirements.txt /tmp/cmd_stress_py_requirements.txt

RUN pip install --no-cache-dir -r /tmp/cmd_stress_py_requirements.txt

WORKDIR /workspace/eloq_waiter

CMD ["sleep", "infinity"]
