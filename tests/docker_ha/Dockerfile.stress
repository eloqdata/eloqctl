FROM python:3.13-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        gdb \
        gdbserver \
        iproute2 \
        less \
        lsof \
        procps \
        strace \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir redis==5.2.1

WORKDIR /workspace/eloq_waiter

CMD ["sleep", "infinity"]
